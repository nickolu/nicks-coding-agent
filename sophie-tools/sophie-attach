#!/usr/bin/env python3
"""Attach a file to a Discord message via Sophie's bridge socket.

Usage:
  sophie-attach /path/to/image.png
  sophie-attach /path/to/image.png "optional caption text"

The file is read locally, sent over the Unix socket as a JSON payload, and the
bot posts it to either the home channel (if `allowed_channel_id` is set) or to Nick's DMs.
"""
import base64
import json
import socket
import sys
from pathlib import Path

SOCKET = "/run/sophie-discord.sock"
MAX_BYTES = 8 * 1024 * 1024  # 8MB Discord upload limit on free-tier servers


def main() -> int:
    if len(sys.argv) < 2:
        print(__doc__, file=sys.stderr)
        return 1
    path = Path(sys.argv[1])
    caption = sys.argv[2] if len(sys.argv) > 2 else ""

    if not path.exists():
        print(f"sophie-attach: file not found: {path}", file=sys.stderr)
        return 1

    data = path.read_bytes()
    if len(data) > MAX_BYTES:
        print(
            f"sophie-attach: file too large ({len(data)/1e6:.1f}MB > {MAX_BYTES/1e6}MB)",
            file=sys.stderr,
        )
        return 1

    payload = {
        "type": "attach",
        "filename": path.name,
        "caption": caption,
        "data_b64": base64.b64encode(data).decode("ascii"),
    }

    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.connect(SOCKET)
        s.sendall(json.dumps(payload).encode("utf-8"))
        s.shutdown(socket.SHUT_WR)
        resp = s.recv(4096).decode("utf-8", errors="replace").strip()
        s.close()
        print(resp)
        return 0 if resp.startswith("ok") else 1
    except FileNotFoundError:
        print(f"sophie-attach: socket {SOCKET} not found (bot not running?)", file=sys.stderr)
        return 1
    except Exception as e:
        print(f"sophie-attach: {e}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
