#!/usr/bin/env python3
"""Generate an image using OpenAI or Google Gemini and save to /notebook/generated-images/.

Usage:
  sophie-image "a red sports car at sunset"
  sophie-image --model gpt-image-1 --size 1536x1024 "wide landscape of mountains"
  sophie-image --model gemini-3-pro-image-preview --aspect 16:9 "cinematic city skyline"

Prints the saved file path on success (so the calling agent can pass it to sophie-attach).
On error, prints the error to stderr and exits non-zero.

Env vars required:
  OPENAI_API_KEY  — for any OpenAI model (default)
  GOOGLE_API_KEY  — for any Gemini model
"""
import argparse
import base64
import os
import re
import sys
import time
from pathlib import Path

OUTPUT_DIR = Path("/notebook/generated-images")

OPENAI_MODELS = {
    "gpt-image-1",
    "gpt-image-1-mini",
    "gpt-image-1.5",
    "gpt-image-2-2026-04-21",
    "chatgpt-image-latest",
    "dall-e-3",
}
GEMINI_MODELS = {
    "gemini-2.5-flash-image",
    "gemini-3-pro-image-preview",
    "gemini-3.1-flash-image-preview",
}
# Friendly aliases
ALIASES = {
    "gemini": "gemini-2.5-flash-image",
    "openai": "gpt-image-2-2026-04-21",
    "gpt-image-2": "gpt-image-2-2026-04-21",
}

OPENAI_SIZES = {"auto", "1024x1024", "1536x1024", "1024x1536"}


def validate_gpt_image_2_size(size: str) -> str:
    """gpt-image-2 accepts custom WxH: edges multiples of 16, both <= 4000px,
    total pixels in [655_360, 8_294_400], aspect within 1:3..3:1.
    Returns a validated 'WxH' string, or raises SystemExit on hard errors.
    Non-numeric inputs (e.g. 'auto') pass through to the API."""
    m = re.fullmatch(r"\s*(\d+)x(\d+)\s*", size)
    if not m:
        return size
    w, h = int(m.group(1)), int(m.group(2))
    if w % 16 or h % 16:
        w = max(16, round(w / 16) * 16)
        h = max(16, round(h / 16) * 16)
    if w > 4000 or h > 4000:
        raise SystemExit(f"error: each edge must be <= 4000px (got {w}x{h})")
    total = w * h
    if total < 655_360:
        raise SystemExit(f"error: total pixels must be >= 655,360 (got {total:,} for {w}x{h})")
    if total > 8_294_400:
        raise SystemExit(f"error: total pixels must be <= 8,294,400 (got {total:,} for {w}x{h})")
    ratio = max(w, h) / min(w, h)
    if ratio > 3.0:
        raise SystemExit(f"error: aspect ratio must be within 1:3..3:1 (got {w}:{h})")
    return f"{w}x{h}"
SIZE_TO_ASPECT = {
    "1024x1024": "1:1",
    "1536x1024": "3:2",
    "1024x1536": "2:3",
    "auto": "1:1",
}


def slugify(s: str, max_len: int = 40) -> str:
    s = re.sub(r"[^a-z0-9]+", "-", s.lower()).strip("-")
    return (s[:max_len] or "image").rstrip("-")


def output_path(prompt: str) -> Path:
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    stamp = time.strftime("%Y%m%d-%H%M%S")
    return OUTPUT_DIR / f"{stamp}-{slugify(prompt)}.png"


def gen_openai(prompt: str, model: str, size: str) -> bytes:
    from openai import OpenAI

    if not os.getenv("OPENAI_API_KEY"):
        raise SystemExit("error: OPENAI_API_KEY is not set in Sophie's .env")
    client = OpenAI()
    if model.startswith("gpt-image-2"):
        size = validate_gpt_image_2_size(size)
    elif size not in OPENAI_SIZES:
        size = "auto"
    resp = client.images.generate(model=model, prompt=prompt, n=1, size=size)
    if not resp.data or not resp.data[0].b64_json:
        raise SystemExit("error: OpenAI returned no image data")
    return base64.b64decode(resp.data[0].b64_json)


def gen_gemini(prompt: str, model: str, aspect: str) -> bytes:
    from google import genai
    from google.genai import types

    if not os.getenv("GOOGLE_API_KEY"):
        raise SystemExit("error: GOOGLE_API_KEY is not set in Sophie's .env")
    client = genai.Client(api_key=os.getenv("GOOGLE_API_KEY"))
    config = types.GenerateContentConfig(
        response_modalities=["Image"],
        image_config=types.ImageConfig(aspect_ratio=aspect),
    )
    response = client.models.generate_content(model=model, contents=[prompt], config=config)
    if not getattr(response, "candidates", None):
        raise SystemExit("error: Gemini returned no candidates (likely rate-limited)")
    parts = response.candidates[0].content.parts if response.candidates[0].content else None
    if not parts:
        raise SystemExit("error: Gemini returned no parts")
    image_parts = [p.inline_data.data for p in parts if p.inline_data]
    if not image_parts:
        raise SystemExit("error: Gemini returned no image data")
    return image_parts[0]


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__.split("\n")[0])
    p.add_argument("prompt", help="Text prompt describing the image")
    p.add_argument(
        "--model",
        default="gemini-2.5-flash-image",
        help=f"Model. OpenAI: {sorted(OPENAI_MODELS)}. Gemini: {sorted(GEMINI_MODELS)}. Aliases: {sorted(ALIASES)}.",
    )
    p.add_argument(
        "--size",
        default="1024x1024",
        help="Pixel size for OpenAI (auto, 1024x1024, 1536x1024, 1024x1536). Ignored for Gemini.",
    )
    p.add_argument(
        "--aspect",
        default=None,
        help="Aspect ratio for Gemini (1:1, 3:2, 2:3, 16:9, etc.). Defaults derived from --size.",
    )
    args = p.parse_args()

    model = ALIASES.get(args.model, args.model)
    out = output_path(args.prompt)

    if model in OPENAI_MODELS:
        image_bytes = gen_openai(args.prompt, model=model, size=args.size)
    elif model in GEMINI_MODELS:
        aspect = args.aspect or SIZE_TO_ASPECT.get(args.size, "1:1")
        image_bytes = gen_gemini(args.prompt, model=model, aspect=aspect)
    else:
        raise SystemExit(f"error: unknown model {model!r}. Use --help to see options.")

    out.write_bytes(image_bytes)
    print(out)
    return 0


if __name__ == "__main__":
    sys.exit(main())
