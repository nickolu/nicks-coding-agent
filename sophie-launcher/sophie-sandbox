#!/bin/bash
set -e
SOPHIE_HOST=/home/sophie/.claude-container
NOTEBOOK=/home/sophie/notebook

if [ ! -s "$SOPHIE_HOST/claude.json" ]; then
  echo '{}' > "$SOPHIE_HOST/claude.json"
  chown sophie:sophie "$SOPHIE_HOST/claude.json"
  chmod 600 "$SOPHIE_HOST/claude.json"
fi

TTY_FLAGS=()
if [ -t 0 ] && [ -t 1 ]; then TTY_FLAGS=(-it); fi

# Persist gws OAuth tokens across container runs.
# `gws` writes credentials to ~/.config/gws/ (credentials.json or credentials.enc + keyring).
# Bind-mounting both .config/gws and the keyring dir covers both storage modes.
mkdir -p "$SOPHIE_HOST/gws-config" "$SOPHIE_HOST/keyrings"
chown sophie:sophie "$SOPHIE_HOST/gws-config" "$SOPHIE_HOST/keyrings"

DOCKER_ARGS=(
  --rm "${TTY_FLAGS[@]}"
  --name "sophie-sandbox-$$"
  --hostname sophie-sandbox
  -e "TZ=${TZ:-UTC}"
  -v "$SOPHIE_HOST:/home/sophie/.claude"
  -v "$SOPHIE_HOST/claude.json:/home/sophie/.claude.json"
  -v "$SOPHIE_HOST/gws-config:/home/sophie/.config/gws"
  -v "$SOPHIE_HOST/keyrings:/home/sophie/.local/share/keyrings"
  -v "/run/sophie-discord.sock:/run/sophie-discord.sock"
  -v "/var/lib/sophie-discord:/var/lib/sophie-discord:ro"
  -v "$SOPHIE_HOST/sophie-notify:/usr/local/bin/sophie-notify:ro"
  -v "$SOPHIE_HOST/sophie-watch:/usr/local/bin/sophie-watch:ro"
  -v "$SOPHIE_HOST/sophie-image:/usr/local/bin/sophie-image:ro"
  -v "$SOPHIE_HOST/sophie-attach:/usr/local/bin/sophie-attach:ro"
  -v "$SOPHIE_HOST/sophie-schedule:/usr/local/bin/sophie-schedule:ro"
  -v "$SOPHIE_HOST/sophie-recent-dms:/usr/local/bin/sophie-recent-dms:ro"
  -v "$SOPHIE_HOST/sophie-task-howl:/usr/local/bin/sophie-task-howl:ro"
  -v "$NOTEBOOK:/notebook"
  --env-file "$SOPHIE_HOST/.env"
  -w /notebook
  sophie-sandbox:latest
)

case "$1" in
  shell) exec docker run "${DOCKER_ARGS[@]}" bash ;;
  -p)    shift; exec docker run "${DOCKER_ARGS[@]}" claude --dangerously-skip-permissions -p "$@" ;;
  *)     exec docker run "${DOCKER_ARGS[@]}" claude --dangerously-skip-permissions "$@" ;;
esac
